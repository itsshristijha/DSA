#include<iostream>
#include<bits/stdc++.h>
using namespace std;
   void math(int*a , int*b){
    int sum = *a + *b;
    int diff = *a - *b;
    *a = sum;
    *b = diff;
   }
   
int main (){
  int a;
  cin >> a;
  int b;
  cin >> b;
  math(&a , &b);
  cout << a << endl;
  cout << b << endl;
    
return 0;
}


