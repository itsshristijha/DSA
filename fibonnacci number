#include<iostream>
#include<bits/stdc++.h>
using namespace std;
int fibonnacci(int n){
    int a = 0;
    int b = 1;
    for(int i = 0; i<n;i++){
        cout << a <<" ";
        int temp = a + b;
        a = b;
        b = temp;
    }
    return n;
}
int main (){
    int n;
    cin >> n;
    cout << fibonnacci(n) << endl;
    return 0;
}
    
